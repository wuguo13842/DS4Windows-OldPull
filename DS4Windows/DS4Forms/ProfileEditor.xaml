												<ComboBoxItem Content="{lex:Loc DualSRumbleModeAccurate}" VerticalContentAlignment="Center"/>
												<ComboBoxItem Content="{lex:Loc DualSRumbleModeLegacy}" VerticalContentAlignment="Center"/>
												<ComboBoxItem Content="{lex:Loc DualSRumbleModeDisabled}" VerticalContentAlignment="Center"/>
											</ComboBox>

											<ComboBox SelectedIndex="{Binding DualSenseHapticPowerLevelPerIndex, FallbackValue=0}" 
													  MinWidth="60" ToolTip="{lex:Loc DualSRumblePowerLevel_Tip}" Margin="4,0,0,0" Width="58"
