								<xctk:IntegerUpDown x:Name="Debouncing" Value="{Binding DebouncingMs}" Minimum="0" Maximum="1000"
													MinWidth="50" VerticalAlignment="Center" VerticalContentAlignment="Center"/>
								<Label Content="{lex:Loc Milliseconds}" VerticalAlignment="Center" Margin="5,0,0,0"/>
							</StackPanel>
						</GroupBox>

