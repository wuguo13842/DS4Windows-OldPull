<UserControl x:Class="DS4WinWPF.DS4Forms.ProfileEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DS4WinWPF.DS4Forms"
             xmlns:localConvert="clr-namespace:DS4WinWPF.DS4Forms.Converters"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:lex="http://wpflocalizeextension.codeplex.com"
             lex:LocalizeDictionary.DesignCulture=""
             lex:ResxLocalizationProvider.DefaultAssembly="DS4Windows"
             lex:ResxLocalizationProvider.DefaultDictionary="Strings"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="1000"
			 xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <UserControl.Resources>
		<GridLength x:Key="AxisConfig_LSRS_1_Width">*</GridLength>
		<sys:Double x:Key="AxisConfig_LSRS_1_MinWidth">80</sys:Double>
	
		<GridLength x:Key="AxisConfig_LSRS_2_Width">110</GridLength>
		<sys:Double x:Key="AxisConfig_LSRS_2_MinWidth">100</sys:Double>
		<sys:Double x:Key="AxisConfig_LSRS_2_MaxWidth">110</sys:Double>
		
		<GridLength x:Key="AxisConfig_DeltaAcceleration_2_Width">*</GridLength>
		<sys:Double x:Key="AxisConfig_DeltaAcceleration_2_MaxWidth">110</sys:Double>
		
        <xctk:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <localConvert:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibilityConverter" />
        <local:ControlIndexCheck x:Key="controlIndexCheck" />
        <local:ResourcePaths x:Key="resourcesPaths" />
    </UserControl.Resources>
    <DockPanel>
		<StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,4,0,10">
			<!-- Profile Label -->
			<TextBlock Text="{lex:Loc ProfileLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
			
			<!-- Profile Name TextBox -->
			<TextBox x:Name="profileNameTxt" Text="" Width="160" 
					 VerticalContentAlignment="Center" VerticalAlignment="Center"/>
			
			<!-- Buttons -->
			<Button x:Name="saveBtn" Content="{lex:Loc SaveProfile}" 
					Margin="10,0,0,0" Click="SaveBtn_Click" 
					VerticalAlignment="Center" VerticalContentAlignment="Center"/>
			<Button x:Name="cancelBtn" Content="{lex:Loc Cancel}" 
					Margin="10,0,0,0" Click="CancelBtn_Click" 
					VerticalAlignment="Center" VerticalContentAlignment="Center"/>
			<Button x:Name="applyBtn" Content="{lex:Loc Apply}" 
					Margin="10,0,0,0" Click="ApplyBtn_Click" IsEnabled="False" 
					VerticalAlignment="Center" VerticalContentAlignment="Center"/>
			<Button x:Name="presetBtn" Content="{lex:Loc SelectPreset}" 
					Margin="10,0,0,0" Click="PresetBtn_Click" 
					VerticalAlignment="Center" VerticalContentAlignment="Center"/>
			
			<!-- Keep Size Button -->
			<Button x:Name="keepSizeBtn" Margin="10,0,0,0" Click="KeepSizeBtn_Click" 
					VerticalAlignment="Center" VerticalContentAlignment="Center">
				<StackPanel Orientation="Horizontal" Margin="0">
					<Image x:Name="sizeImage" 
						   Source="{Binding Source={StaticResource resourcesPaths}, Path=SizePNG}" 
						   Width="20" Height="20" VerticalAlignment="Center"/>
					<TextBlock x:Name="sizeMsg" Text="{lex:Loc KeepSizeMessage}" 
							   Margin="4,0,0,0" VerticalAlignment="Center"/>
				</StackPanel>
			</Button>
		</StackPanel>
        <TabControl x:Name="sidebarTabControl" Width="480" DockPanel.Dock="Left" SelectionChanged="SidebarTabControl_SelectionChanged">
            <TabItem Header="{lex:Loc Controls}">
                <DockPanel Width="470" LastChildFill="False">
                    <DockPanel.Background>
                        <SolidColorBrush Color="DimGray"/>
                    </DockPanel.Background>
                    <Canvas x:Name="conCanvas" Width="440" Height="240" Margin="0,10,0,0" DockPanel.Dock="Top" >
                        <Canvas.Resources>
                            <ContextMenu x:Key="presetMenu">
                                <MenuItem x:Name="controlNameItem" Header="Name" IsEnabled="False" />
                                <Separator />
                                <MenuItem Header="Default" Tag="0" Click="PresetMenuItem_Click" />
                                <MenuItem Header="DPad">
                                    <MenuItem Header="Normal" Tag="1" CommandParameter="0" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Inverted" Tag="1" CommandParameter="1" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Inverted X" Tag="1" CommandParameter="2" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Inverted Y" Tag="1" CommandParameter="3" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Rotate 90&#xb0;" Tag="1" CommandParameter="4" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Rotate -90&#xb0;" Tag="1" CommandParameter="5" Click="PresetMenuItem_Click" />
                                </MenuItem>
                                <MenuItem Header="Left Stick">
                                    <MenuItem Header="Normal" Tag="2" CommandParameter="0" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Inverted" Tag="2" CommandParameter="1" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Inverted X" Tag="2" CommandParameter="2" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Inverted Y" Tag="2" CommandParameter="3" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Rotate 90&#xb0;" Tag="2" CommandParameter="4" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Rotate -90&#xb0;" Tag="2" CommandParameter="5" Click="PresetMenuItem_Click" />
                                </MenuItem>
                                <MenuItem Header="Right Stick">
                                    <MenuItem Header="Normal" Tag="3" CommandParameter="0" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Inverted" Tag="3" CommandParameter="1" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Inverted X" Tag="3" CommandParameter="2" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Inverted Y" Tag="3" CommandParameter="3" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Rotate 90&#xb0;" Tag="3" CommandParameter="4" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Rotate -90&#xb0;" Tag="3" CommandParameter="5" Click="PresetMenuItem_Click" />
                                </MenuItem>
                                <MenuItem Header="Face Buttons">
                                    <MenuItem Header="Normal" Tag="4" CommandParameter="0" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Rotate 90&#xb0;" Tag="4" CommandParameter="1" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Rotate -90&#xb0;" Tag="4" CommandParameter="2" Click="PresetMenuItem_Click" />
                                </MenuItem>
                                <MenuItem Header="WASD">
                                    <MenuItem Header="Normal" Tag="5" CommandParameter="0" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Rotate 90&#xb0;" Tag="5" CommandParameter="1" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Rotate -90&#xb0;" Tag="5" CommandParameter="2" Click="PresetMenuItem_Click" />
                                </MenuItem>
                                <MenuItem Header="Arrow Keys">
                                    <MenuItem Header="Normal" Tag="6" CommandParameter="0" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Rotate 90&#xb0;" Tag="6" CommandParameter="1" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Rotate -90&#xb0;" Tag="6" CommandParameter="2" Click="PresetMenuItem_Click" />
                                </MenuItem>
                                <MenuItem Header="Mouse">
                                    <MenuItem Header="Normal" Tag="7" CommandParameter="0" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Inverted" Tag="7" CommandParameter="1" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Inverted X" Tag="7" CommandParameter="2" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Inverted Y" Tag="7" CommandParameter="3" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Rotate 90&#xb0;" Tag="7" CommandParameter="4" Click="PresetMenuItem_Click" />
                                    <MenuItem Header="Rotate -90&#xb0;" Tag="7" CommandParameter="5" Click="PresetMenuItem_Click" />
                                </MenuItem>
                                <MenuItem Header="Unbound" Tag="8" Click="PresetMenuItem_Click" />
                            </ContextMenu>
                        </Canvas.Resources>

                        <Image Source="{Binding Source={StaticResource resourcesPaths}, Path=DS4ConfigPNG}" Width="440" Height="220" Stretch="Uniform"/>

                        <Button x:Name="ds4LightbarColorBtn" Width="138" Height="12" Canvas.Left="150" Canvas.Top="28"
                                Background="{x:Null}" BorderBrush="{x:Null}" MouseEnter="Ds4LightbarColorBtn_MouseEnter" MouseLeave="Ds4LightbarColorBtn_MouseLeave" Click="Ds4LightbarColorBtn_Click">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{x:Null}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Rectangle x:Name="lightbarRect" Fill="{Binding LightbarBrush,FallbackValue=Green}" Width="{Binding Path=Width, ElementName=ds4LightbarColorBtn}"
                                       Height="{Binding Path=Height, ElementName=ds4LightbarColorBtn}">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="{Binding Source={StaticResource resourcesPaths}, Path=DS4LightbarPNG}" />
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </Button>

                        <Image x:Name="picBoxHover" IsEnabled="False" Source="{Binding Source={StaticResource resourcesPaths}, Path=DS4ConfigRSPNG}" Height="48" Width="48" Canvas.Left="447" Canvas.Top="5" />
                        <Image x:Name="picBoxHover2" IsEnabled="False" Source="{Binding Source={StaticResource resourcesPaths}, Path=DS4ConfigRSPNG}" Height="48" Width="48" Canvas.Left="0" Canvas.Top="0" Stretch="Fill" />

                        <Button Content="Cross" x:Name="crossConBtn" Canvas.Left="330" Canvas.Top="125" Width="26" Height="26" Click="HoverConBtn_Click" Style="{StaticResource NoBGHoverBtn}" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave" MouseRightButtonUp="ConBtn_MouseRightButtonUp" />
                        <Button Content="Circle" x:Name="circleConBtn" Canvas.Left="357" Canvas.Top="99" Width="26" Height="26" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave" MouseRightButtonUp="ConBtn_MouseRightButtonUp" />
                        <Button Content="Square" x:Name="squareConBtn" Canvas.Left="300" Canvas.Top="98" Width="26" Height="26" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave" MouseRightButtonUp="ConBtn_MouseRightButtonUp" />
                        <Button Content="Triangle" x:Name="triangleConBtn" Canvas.Left="330" Canvas.Top="74" Width="26" Height="26" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave" MouseRightButtonUp="ConBtn_MouseRightButtonUp" />

                        <Button Content="L1" x:Name="l1ConBtn" Canvas.Left="75" Canvas.Top="22" Width="50" Height="18" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave" />
                        <Button Content="R1" x:Name="r1ConBtn" Canvas.Left="317" Canvas.Top="22" Width="50" Height="18" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave" />
                        <Button Content="L2" x:Name="l2ConBtn" Canvas.Left="78" Canvas.Top="0" Width="46" Height="20" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave" />
                        <Button Content="R2" x:Name="r2ConBtn" Canvas.Left="316" Canvas.Top="0" Width="46" Height="20" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave" />

                        <Button Content="Share" x:Name="shareConBtn" Canvas.Left="134" Canvas.Top="63" Width="16" Height="24" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave" />
                        <Button Content="Options" x:Name="optionsConBtn" Canvas.Left="291" Canvas.Top="63" Width="16" Height="24" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave" />
                        <Button Content="Guide" x:Name="guideConBtn" Canvas.Left="211" Canvas.Top="144" Width="20" Height="20" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave" />
                        <Button Content="Mute" x:Name="muteConBtn" Canvas.Left="0" Canvas.Top="0" Width="0" Height="0" Style="{StaticResource NoBGHoverBtn}" Visibility="Collapsed" />
                        <Button Content="Function Left" x:Name="fnlConBtn" Canvas.Left="0" Canvas.Top="0" Width="0" Height="0" Style="{StaticResource NoBGHoverBtn}" Visibility="Collapsed" />
                        <Button Content="Function Right" x:Name="fnrConBtn" Canvas.Left="0" Canvas.Top="0" Width="0" Height="0" Style="{StaticResource NoBGHoverBtn}" Visibility="Collapsed" />
                        <Button Content="Bottom Left Paddle" x:Name="blpConBtn" Canvas.Left="0" Canvas.Top="0" Width="0" Height="0" Style="{StaticResource NoBGHoverBtn}" Visibility="Collapsed" />
                        <Button Content="Bottom Right Paddle" x:Name="brpConBtn" Canvas.Left="0" Canvas.Top="0" Width="0" Height="0" Style="{StaticResource NoBGHoverBtn}" Visibility="Collapsed" />

                        <Button Content="Left Touch" x:Name="leftTouchConBtn" Canvas.Left="158" Canvas.Top="69" Width="37" Height="51" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave" />
                        <Button Content="Multi Touch" x:Name="multiTouchConBtn" Canvas.Left="199" Canvas.Top="74" Width="41" Height="45" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave" />
                        <Button Content="Right Touch" x:Name="rightTouchConBtn" Canvas.Left="251" Canvas.Top="70" Width="32" Height="53" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave" />
                        <Button Content="Top Touch" x:Name="topTouchConBtn" Canvas.Left="157" Canvas.Top="46" Width="125" Height="23" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave" />

                        <Button Content="L3" x:Name="l3ConBtn" Canvas.Left="138" Canvas.Top="147" Width="42" Height="42" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave"
                                MouseRightButtonUp="ConBtn_MouseRightButtonUp" />
                        <Button Content="LSU" x:Name="lsuConBtn" Canvas.Left="150" Canvas.Top="140" Width="17" Height="15" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave"
                                MouseRightButtonUp="ConBtn_MouseRightButtonUp" />
                        <Button Content="LSR" x:Name="lsrConBtn" Canvas.Left="172" Canvas.Top="162" Width="17" Height="15" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave"
                                MouseRightButtonUp="ConBtn_MouseRightButtonUp" />
                        <Button Content="LSD" x:Name="lsdConBtn" Canvas.Left="150" Canvas.Top="180" Width="17" Height="15" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave"
                                MouseRightButtonUp="ConBtn_MouseRightButtonUp" />
                        <Button Content="LSL" x:Name="lslConBtn" Canvas.Left="126" Canvas.Top="162" Width="17" Height="15" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave"
                                MouseRightButtonUp="ConBtn_MouseRightButtonUp" />

                        <Button Content="R3" x:Name="r3ConBtn" Canvas.Left="262" Canvas.Top="149" Width="42" Height="42" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave"
                                MouseRightButtonUp="ConBtn_MouseRightButtonUp" />
                        <Button Content="RSU" x:Name="rsuConBtn" Canvas.Left="275" Canvas.Top="142" Width="17" Height="15" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave"
                                MouseRightButtonUp="ConBtn_MouseRightButtonUp" />
                        <Button Content="RSR" x:Name="rsrConBtn" Canvas.Left="298" Canvas.Top="162" Width="17" Height="15" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave"
                                MouseRightButtonUp="ConBtn_MouseRightButtonUp" />
                        <Button Content="RSD" x:Name="rsdConBtn" Canvas.Left="275" Canvas.Top="180" Width="17" Height="15" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave"
                                MouseRightButtonUp="ConBtn_MouseRightButtonUp" />
                        <Button Content="RSL" x:Name="rslConBtn" Canvas.Left="248" Canvas.Top="162" Width="17" Height="15" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave"
                                MouseRightButtonUp="ConBtn_MouseRightButtonUp" />

                        <Button Content="Up" x:Name="upConBtn" Canvas.Left="88" Canvas.Top="74" Width="20" Height="35" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave"
                                MouseRightButtonUp="ConBtn_MouseRightButtonUp" />
                        <Button Content="Right" x:Name="rightConBtn" Canvas.Left="103" Canvas.Top="103" Width="35" Height="20" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave"
                                MouseRightButtonUp="ConBtn_MouseRightButtonUp" />
                        <Button Content="Down" x:Name="downConBtn" Canvas.Left="88" Canvas.Top="114" Width="20" Height="35" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave"
                                MouseRightButtonUp="ConBtn_MouseRightButtonUp" />
                        <Button Content="Left" x:Name="leftConBtn" Canvas.Left="56" Canvas.Top="103" Width="35" Height="20" Style="{StaticResource NoBGHoverBtn}" Click="HoverConBtn_Click" MouseEnter="ContBtn_MouseEnter" MouseLeave="ContBtn_MouseLeave"
                                MouseRightButtonUp="ConBtn_MouseRightButtonUp" />

                        <Label x:Name="highlightControlDisplayLb" Content="" Canvas.Left="150" Canvas.Top="208" MinWidth="150"
                               HorizontalContentAlignment="Center">
                            <Label.Foreground>
                                <SolidColorBrush Color="{DynamicResource {x:Static SystemColors.ControlColorKey}}"/>
                            </Label.Foreground>
                        </Label>
                    </Canvas>

                    <ListBox x:Name="mappingListBox" DockPanel.Dock="Bottom" Height="200" ItemsSource="{Binding Mappings}"
                                SelectedIndex="{Binding SelectedIndex}" Margin="6" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                MouseDoubleClick="MappingListBox_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ControlName,StringFormat='\{0\}: '}" />
                                    <TextBlock Text="{Binding MappingName}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </TabItem>
            <TabItem x:Name="specialActionsTab" Header="{lex:Loc SpecialActionsTab}">
                <DockPanel x:Name="specialActionDockPanel">
                    <DockPanel x:Name="baseSpeActPanel" DockPanel.Dock="Top">
                        <UniformGrid Rows="1" Columns="4" DockPanel.Dock="Top">
                            <Button x:Name="newActionBtn" Content="{lex:Loc NewAction}" Margin="0,0,5,0" Click="NewActionBtn_Click" />
                            <Button x:Name="editActionBtn" Content="{lex:Loc EditAction}" IsEnabled="{Binding ItemSelected}" Margin="5,0" Click="EditActionBtn_Click" />
                            <Button x:Name="removeActionBtn" Content="{lex:Loc RemoveAction}" IsEnabled="{Binding ItemSelected}" Margin="5,0,0,0" Click="RemoveActionBtn_Click" />
                            <Button Content="{lex:Loc ExportSpecialActions}" Margin="5 0 0 0" Click="ExportSpecialActions_OnClick"/>
                        </UniformGrid>

                        <ListView x:Name="specialActionsLV" ItemsSource="{Binding ActionCol}" SelectedIndex="{Binding SpecialActionIndex}" SelectedItem="{Binding CurrentSpecialActionItem,Mode=OneWayToSource}" DockPanel.Dock="Bottom" Margin="0,10,0,0">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="{lex:Loc Name}" Width="150">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <CheckBox IsChecked="{Binding Active}" Click="SpecialActionCheckBox_Click" />
                                                    <TextBlock Text="{Binding ActionName}" Margin="4,0,0,0" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="{lex:Loc Trigger}" DisplayMemberBinding="{Binding Controls}" Width="100" />
                                    <GridViewColumn Header="{lex:Loc Action}" DisplayMemberBinding="{Binding TypeName}" Width="200" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </DockPanel>
            </TabItem>
			<TabItem x:Name="contReadingsTab" Header="{lex:Loc ControllerReadings}" IsEnabled="False">
				<local:ControllerReadingsControl x:Name="conReadingsUserCon" />
			</TabItem>
        </TabControl>

        <TabControl x:Name="profileSettingsTabCon" DockPanel.Dock="Right" Margin="10,0,0,0" Padding="6">
            <TabControl.Resources>
                <Thickness x:Key="spaceMargin" Bottom="8" />
            </TabControl.Resources>

			<!-- 轴向相关配置 Axis Config -->
            <TabItem Header="{lex:Loc AxisConfig}" Height="24" Margin="-2,0,-2,0" VerticalAlignment="Bottom">
                <TabItem.Resources>
                    <Thickness x:Key="spaceMargin" Left="10" Bottom="6" />
                    <Style x:Key="gridRowHeight" TargetType="{x:Type RowDefinition}">
                        <Setter Property="Height" Value="30" />
                    </Style>
                </TabItem.Resources>
                <ScrollViewer>
                    <StackPanel>
					

						<!-- LS 和 RS 并列的外层Grid -->
						<Grid Margin="0,4,0,0">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="5"/> <!-- 间距 -->
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>

							<!-- LS 列 -->
							<GroupBox Grid.Column="0" Header="LS" Margin="0,0,0,10">
								<Grid>
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto"/>
										<RowDefinition Height="Auto"/>
									</Grid.RowDefinitions>
									
									<!-- Output Mode 行 - 固定在顶部 -->
									<Grid Grid.Row="0" Margin="0,0,0,5">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="Auto"/>
											<ColumnDefinition Width="*"/>
										</Grid.ColumnDefinitions>
										<Label Content="{lex:Loc OutputMode}" VerticalAlignment="Center"/>
										<ComboBox Grid.Column="1" SelectedIndex="{Binding LSOutputIndex,FallbackValue='0'}" 
												  HorizontalAlignment="Left"  MinWidth="80" MaxWidth="160" VerticalContentAlignment="Center">
											<ComboBoxItem Content="{lex:Loc None}" />
											<ComboBoxItem Content="{lex:Loc Controls}" />
											<ComboBoxItem Content="{lex:Loc FlickStick}" />
										</ComboBox>
									</Grid>

									<!-- TabControl 占据剩余空间并自动适应高度 -->
									<TabControl Grid.Row="1" SelectedIndex="{Binding LSOutputIndex,Mode=OneWay,FallbackValue='0'}" 
												BorderBrush="{x:Null}" Padding="0" Margin="0,5,0,0"
												VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
										<TabItem Header="{lex:Loc None}" Visibility="Collapsed" />
										
										<!-- Controls Tab -->
										<TabItem Header="{lex:Loc Controls}" Visibility="Collapsed">
											<StackPanel Margin="0,0,5,0">
												<!-- DeadZone Type 行 -->
												<Grid Margin="0,0,0,5">
													<Grid.ColumnDefinitions>
														<ColumnDefinition Width="Auto"/>
														<ColumnDefinition Width="*"/>
													</Grid.ColumnDefinitions>
													<Label Content="{lex:Loc DeadZoneType}" VerticalAlignment="Center"/>
													<ComboBox Grid.Column="1" SelectedIndex="{Binding LSDeadTypeIndex,FallbackValue='0'}" 
															  HorizontalAlignment="Left"  MinWidth="80" MaxWidth="160" VerticalContentAlignment="Center">
														<ComboBoxItem Content="{lex:Loc Radial}" />
														<ComboBoxItem Content="{lex:Loc Axial}" />
													</ComboBox>
												</Grid>

												<!-- DeadZone Type specific controls (Radial/Axial) -->
												<TabControl SelectedIndex="{Binding LSDeadTypeIndex,Mode=OneWay,FallbackValue='0'}" 
															BorderBrush="{x:Null}" Padding="0" Margin="0,5,0,5">
													<TabItem Header="Radial" Visibility="Collapsed">
														<StackPanel>
															<!-- 统一的外部Grid - Radial Tab内的所有控件 -->
															<Grid>
																<Grid.RowDefinitions>
																	<RowDefinition Height="Auto"/>
																	<RowDefinition Height="Auto"/>
																	<RowDefinition Height="Auto"/>
																	<RowDefinition Height="Auto"/>
																	<RowDefinition Height="Auto"/>
																	<RowDefinition Height="Auto"/>
																</Grid.RowDefinitions>
																<Grid.ColumnDefinitions>
																	<ColumnDefinition Width="{StaticResource AxisConfig_LSRS_1_Width}" MinWidth="{StaticResource AxisConfig_LSRS_1_MinWidth}"/>
																	<ColumnDefinition Width="{StaticResource AxisConfig_LSRS_2_Width}"/>
																</Grid.ColumnDefinitions>
																
																<!-- DeadZone -->
																<Label Grid.Row="0" Grid.Column="0" Content="{lex:Loc DeadZone}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
																<xctk:DoubleUpDown Grid.Row="0" Grid.Column="1" Value="{Binding LSDeadZone,UpdateSourceTrigger=LostFocus}" 
																				  FormatString="F2" HorizontalAlignment="Stretch" Margin="0,0,0,5"
																				  Maximum="1.0" Minimum="0.0" Increment="0.1"/>

																<!-- MaxZone -->
																<Label Grid.Row="1" Grid.Column="0" Content="{lex:Loc MaxZone}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
																<xctk:DoubleUpDown Grid.Row="1" Grid.Column="1" Value="{Binding LSMaxZone}" FormatString="F2" 
																				  HorizontalAlignment="Stretch" Margin="0,0,0,5"
																				  Maximum="1.0" Minimum="0.0" Increment="0.1"/>

																<!-- AntiDeadZone -->
																<Label Grid.Row="2" Grid.Column="0" Content="{lex:Loc AntiDeadZone}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
																<xctk:DoubleUpDown Grid.Row="2" Grid.Column="1" Value="{Binding LSAntiDeadZone}" FormatString="F2" 
																				  HorizontalAlignment="Stretch" Margin="0,0,0,5"
																				  Maximum="1.0" Minimum="0.0" Increment="0.1">
																	<xctk:DoubleUpDown.ToolTip>
																		<TextBlock TextWrapping="Wrap" Text="{lex:Loc AntiDeadzoneTooltip}"/>
																	</xctk:DoubleUpDown.ToolTip>
																</xctk:DoubleUpDown>

																<!-- MaxOutput -->
																<Label Grid.Row="3" Grid.Column="0" Content="{lex:Loc MaxOutput}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
																<Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,5">
																	<Grid.ColumnDefinitions>
																		<ColumnDefinition Width="*"/>
																		<ColumnDefinition Width="Auto"/>
																	</Grid.ColumnDefinitions>
																	<xctk:DoubleUpDown Grid.Column="0" Value="{Binding LSMaxOutput}" FormatString="F2" 
																					  HorizontalAlignment="Stretch"
																					  Maximum="1.0" Minimum="0.0" Increment="0.1">
																		<xctk:DoubleUpDown.ToolTip>
																			<TextBlock TextWrapping="Wrap" Text="{lex:Loc StickMaxOutputTooltip}"/>
																		</xctk:DoubleUpDown.ToolTip>
																	</xctk:DoubleUpDown>
																	<CheckBox Grid.Column="1" Content="{lex:Loc ForceCheckBox}"  VerticalAlignment="Bottom" 
																			  IsChecked="{Binding LSMaxOutputForce}" 
																			  ToolTip="{lex:Loc StickMaxOutputForceTooltip}" Margin="8,0,0,0"/>
																</Grid>

																<!-- VerticalScale -->
																<Label Grid.Row="4" Grid.Column="0" Content="{lex:Loc VerticalScale}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
																<xctk:DoubleUpDown Grid.Row="4" Grid.Column="1" Value="{Binding LSVerticalScale}" FormatString="F2" 
																				  HorizontalAlignment="Stretch" Margin="0,0,0,5"
																				  Maximum="4.0" Minimum="0.0" Increment="0.1"/>

																<!-- Sensitivity -->
																<Label Grid.Row="5" Grid.Column="0" Content="{lex:Loc Sensitivity}" ContentStringFormat="{}{0}:" VerticalAlignment="Center"/>
																<xctk:DoubleUpDown Grid.Row="5" Grid.Column="1" FormatString="F2" Value="{Binding LSSens}" 
																				  HorizontalAlignment="Stretch"
																				  Maximum="5.0" Minimum="0.1" Increment="0.1"/>
															</Grid>
														</StackPanel>
													</TabItem>

													<TabItem Header="{lex:Loc Axial}" Visibility="Collapsed">
														<local:AxialStickUserControl x:Name="axialLSStickControl" 
																					  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
													</TabItem>
												</TabControl>

												<!-- 统一的外部Grid - Radial Tab外的所有控件 -->
												<Grid>
													<Grid.RowDefinitions>
														<RowDefinition Height="Auto"/>
														<RowDefinition Height="Auto"/>
														<RowDefinition Height="Auto"/>
														<RowDefinition Height="Auto"/>
														<RowDefinition Height="Auto"/>
														<RowDefinition Height="Auto"/>
														<RowDefinition Height="Auto"/>
														<RowDefinition Height="Auto"/>
														<RowDefinition Height="Auto"/>
														<RowDefinition Height="Auto"/>
														<RowDefinition Height="Auto"/>
														<RowDefinition Height="Auto"/>
														<RowDefinition Height="Auto"/>
														<RowDefinition Height="Auto"/>
														<RowDefinition Height="Auto"/>
														<RowDefinition Height="Auto"/> <!-- 第16行给Delta Acceleration -->
													</Grid.RowDefinitions>
													<Grid.ColumnDefinitions>
														<ColumnDefinition Width="{StaticResource AxisConfig_LSRS_1_Width}" MinWidth="{StaticResource AxisConfig_LSRS_1_MinWidth}"/>
														<ColumnDefinition Width="{StaticResource AxisConfig_LSRS_2_Width}"/>
													</Grid.ColumnDefinitions>
													
													<!-- Output Curve -->
													<Label Grid.Row="0" Grid.Column="0" Content="{lex:Loc OutputCurve}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
													<ComboBox Grid.Row="0" Grid.Column="1" SelectedIndex="{Binding LSOutputCurveIndex}" 
															  HorizontalAlignment="Stretch" Margin="0,0,0,5">
														<ComboBoxItem Content="{lex:Loc Linear}" />
														<ComboBoxItem Content="{lex:Loc EnhancedPrecision}" />
														<ComboBoxItem Content="{lex:Loc Quadratic}" />
														<ComboBoxItem Content="{lex:Loc Cubic}" />
														<ComboBoxItem Content="{lex:Loc EaseoutQuad}" />
														<ComboBoxItem Content="{lex:Loc EaseoutCubic}" />
														<ComboBoxItem Content="{lex:Loc Custom}" />
													</ComboBox>

													<!-- Custom Curve -->
													<Label Grid.Row="1" Grid.Column="0" Content="{lex:Loc CustomCurveLabel}" VerticalAlignment="Center" Margin="0,0,0,5"/>
													<DockPanel Grid.Row="1" Grid.Column="1" IsEnabled="{Binding LSCustomCurveSelected}" Margin="0,0,0,5">
														<Button x:Name="lsCustomEditorBtn" Content="..." Tag="LS" Width="20" 
																DockPanel.Dock="Right" Click="CustomEditorBtn_Click" Margin="5,0,0,0"/>
														<TextBox Text="{Binding LSCustomCurve,UpdateSourceTrigger=LostFocus,FallbackValue='0.00, 0.00, 1.00, 1.00'}" 
																 Height="22" HorizontalAlignment="Stretch"/>
													</DockPanel>

													<!-- Square Stick -->
													<Label Grid.Row="2" Grid.Column="0" Content="{lex:Loc SquareStick}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
													<Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,5">
														<Grid.ColumnDefinitions>
															<ColumnDefinition Width="Auto"/>
															<ColumnDefinition Width="*"/>
														</Grid.ColumnDefinitions>
														<CheckBox Grid.Column="0" IsChecked="{Binding LSSquareStick}" VerticalAlignment="Center"/>
														<xctk:DoubleUpDown Grid.Column="1" FormatString="F1" Value="{Binding LSSquareRoundness,FallbackValue=5}"
																		   HorizontalAlignment="Stretch"
																		   Minimum="0.0" Maximum="1000.0" Increment="1.0" 
																		   IsEnabled="{Binding LSSquareStick}" Margin="8,0,0,0"/>
													</Grid>

													<!-- Rotation -->
													<Label Grid.Row="3" Grid.Column="0" Content="{lex:Loc Rotation}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
													<DockPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,5">
														<TextBlock Text="&#xb0;" DockPanel.Dock="Right" FontSize="18" Margin="5,0,0,0" VerticalAlignment="Center"/>
														<xctk:IntegerUpDown Value="{Binding LSRotation}" 
																			HorizontalAlignment="Stretch"
																			Minimum="-180" Maximum="180">
															<xctk:IntegerUpDown.ToolTip>
																<TextBlock TextWrapping="Wrap" Text="{lex:Loc StickRotationTooltip}"/>
															</xctk:IntegerUpDown.ToolTip>
														</xctk:IntegerUpDown>
													</DockPanel>

													<!-- Fuzz -->
													<Label Grid.Row="4" Grid.Column="0" Content="{lex:Loc Fuzz}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
													<DockPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,5">
														<TextBlock Text="{lex:Loc Units}" DockPanel.Dock="Right" FontSize="10" Margin="5,0,0,0" VerticalAlignment="Center"/>
														<xctk:IntegerUpDown Value="{Binding LSFuzz}" 
																			HorizontalAlignment="Stretch"
																			Minimum="0" Maximum="100">
															<xctk:IntegerUpDown.ToolTip>
																<TextBlock TextWrapping="Wrap" Text="{lex:Loc StickFuzzTooltip}"/>
															</xctk:IntegerUpDown.ToolTip>
														</xctk:IntegerUpDown>
													</DockPanel>

													<!-- Anti Snapback -->
													<Label Grid.Row="5" Grid.Column="0" Content="{lex:Loc AntiSnapback}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
													<Grid Grid.Row="5" Grid.Column="1" Margin="0,0,0,5">
														<Grid.ColumnDefinitions>
															<ColumnDefinition Width="Auto"/>
															<ColumnDefinition Width="*"/>
															<ColumnDefinition Width="Auto"/>
														</Grid.ColumnDefinitions>
														<CheckBox Grid.Column="0" IsChecked="{Binding LSAntiSnapback}" VerticalAlignment="Center"/>
														<xctk:DoubleUpDown Grid.Column="1" FormatString="F1" Value="{Binding LSAntiSnapbackDelta, FallbackValue=135}"
																		   HorizontalAlignment="Stretch"
																		   Minimum="0.0" Maximum="256.0" Increment="1.0" 
																		   IsEnabled="{Binding LSAntiSnapback}" Margin="8,0,0,0"/>
														<TextBlock Grid.Column="2" Text="{lex:Loc Units}" FontSize="10" VerticalAlignment="Center" Margin="5,0,0,0"/>
													</Grid>

													<!-- Anti Snapback Timing -->
													<Label Grid.Row="6" Grid.Column="0" Content="{lex:Loc AntiSnapbackTiming}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
													<Grid Grid.Row="6" Grid.Column="1" Margin="0,0,0,5">
														<Grid.ColumnDefinitions>
															<ColumnDefinition Width="*"/>
															<ColumnDefinition Width="Auto"/>
														</Grid.ColumnDefinitions>
														<xctk:IntegerUpDown Grid.Column="0" Value="{Binding LSAntiSnapbackTimeout}" 
																			HorizontalAlignment="Stretch"
																			Minimum="0" Maximum="1000" Increment="1" 
																			IsEnabled="{Binding LSAntiSnapback}"/>
														<TextBlock Grid.Column="1" Text="{lex:Loc Milliseconds}" FontSize="10" Margin="5,0,0,0" VerticalAlignment="Center"/>
													</Grid>

													<!-- Outer Button - 第一行 -->
													<Label Grid.Row="7" Grid.Column="0" Content="{lex:Loc OuterBtn}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
													<Button Grid.Row="7" Grid.Column="1" Content="{lex:Loc OuterBind}" MinWidth="40" 
															Tag="{Binding LSOuterBind, Source={StaticResource controlIndexCheck}}"
															Click="StickOuterBindButton_Click" 
															ToolTip="{lex:Loc StickOuterBindTooltip}" 
															HorizontalAlignment="Stretch" Margin="0,0,0,5"/>
													
													<!-- Outer Button - 第二行 -->
													<Grid Grid.Row="8" Grid.Column="1" Margin="0,0,0,5">
														<Label x:Name="lsOuterBindLb" Content="{Binding MappingName,FallbackValue=Unassigned}"
															   HorizontalAlignment="Center"/>
													</Grid>

													<!-- Outer Button Deadzone -->
													<Label Grid.Row="9" Grid.Column="0" Content="{lex:Loc OuterBtnDead}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
													<Grid Grid.Row="9" Grid.Column="1" Margin="0,0,0,5">
														<Grid.ColumnDefinitions>
															<ColumnDefinition Width="*"/>
															<ColumnDefinition Width="Auto"/>
														</Grid.ColumnDefinitions>
														<xctk:DoubleUpDown Grid.Column="0" FormatString="F2" Value="{Binding LSOuterBindDead}"
																		   HorizontalAlignment="Stretch"
																		   Minimum="0.0" Maximum="1.0" Increment="0.1"
																		   ToolTip="{lex:Loc StickOuterBindDeadTooltip}"/>
														<CheckBox Grid.Column="1" Content="{lex:Loc Invert}" IsChecked="{Binding LSOuterBindInvert}" 
																  ToolTip="{lex:Loc StickOuterBindInvertTooltip}" Margin="8,0,0,0"/>
													</Grid>

													<!-- Calibration Section 标题 - 跨两列 -->
													<Label Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" 
														   Content="{lex:Loc StickCalibration}" 
														   HorizontalContentAlignment="Center" 
														   FontWeight="Bold" Margin="0,10,0,5"/>

													<!-- X Axis Offset -->
													<Label Grid.Row="11" Grid.Column="0" Content="{lex:Loc XAxisOffset}" VerticalAlignment="Center" Margin="0,0,0,5"/>
													<xctk:SByteUpDown Grid.Row="11" Grid.Column="1" Value="{Binding LeftStickDriftXAxis,UpdateSourceTrigger=LostFocus}" 
																	  HorizontalAlignment="Stretch" Margin="0,0,0,5"
																	  Maximum="127" Minimum="-127" Increment="1"/>

													<!-- Y Axis Offset -->
													<Label Grid.Row="12" Grid.Column="0" Content="{lex:Loc YAxisOffset}" VerticalAlignment="Center" Margin="0,0,0,5"/>
													<xctk:SByteUpDown Grid.Row="12" Grid.Column="1" Value="{Binding LeftStickDriftYAxis,UpdateSourceTrigger=LostFocus}" 
																	  HorizontalAlignment="Stretch" Margin="0,0,0,5"
																	  Maximum="127" Minimum="-127" Increment="1"/>

													<!-- Calibrate Button - 跨两列 -->
													<Button Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="2" 
															Content="{lex:Loc AutomaticallyRecalibrateStick}" 
															Click="CalibrateStick_OnClick" Tag="0" 
															HorizontalAlignment="Stretch" Padding="5" Margin="0,5,0,10"/>

													<!-- Delta Acceleration Section - 跨两列 -->
													<GroupBox Grid.Row="14" Grid.Column="0" Grid.ColumnSpan="2" 
															  Header="{lex:Loc DeltaAcceleration}" Margin="0,5,0,0">
														<StackPanel>
															<!-- Delta Enabled -->
															<Grid Margin="0,0,0,5">
																<Grid.ColumnDefinitions>
																	<ColumnDefinition Width="{StaticResource AxisConfig_LSRS_1_Width}" MinWidth="{StaticResource AxisConfig_LSRS_1_MinWidth}"/>
																	<ColumnDefinition Width="{StaticResource AxisConfig_LSRS_2_Width}"/>
																</Grid.ColumnDefinitions>
																<Label Content="{lex:Loc Enabled}" ContentStringFormat="{}{0}:" VerticalAlignment="Center"/>
																<CheckBox Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right"/>

															</Grid>

															<!-- Delta Settings Expander -->
															<Expander Header="{lex:Loc Settings}">
																<!-- 统一的外部Grid - Expander内的所有控件 -->
																<Grid Margin="0,5,0,0">
																	<Grid.RowDefinitions>
																		<RowDefinition Height="Auto"/>
																		<RowDefinition Height="Auto"/>
																		<RowDefinition Height="Auto"/>
																		<RowDefinition Height="Auto"/>
																		<RowDefinition Height="Auto"/>
																	</Grid.RowDefinitions>
																	<Grid.ColumnDefinitions>
																		<ColumnDefinition Width="{StaticResource AxisConfig_LSRS_1_Width}" MinWidth="{StaticResource AxisConfig_LSRS_1_MinWidth}"/>
																		<ColumnDefinition Width="{StaticResource AxisConfig_LSRS_2_Width}"/>
																	</Grid.ColumnDefinitions>
																	
																	<!-- Multiplier -->
																	<Label Grid.Row="0" Grid.Column="0" Content="{lex:Loc Multiplier}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
																	<xctk:DoubleUpDown Grid.Row="0" Grid.Column="1" FormatString="F2" Value="{Binding LSDeltaMultiplier}"
																					  HorizontalAlignment="Stretch" Margin="0,0,0,5"
																					  Minimum="0.0" Maximum="10.0" Increment="0.1"/>

																	<!-- Max Travel -->
																	<Label Grid.Row="1" Grid.Column="0" Content="{lex:Loc MaxTravel}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
																	<xctk:DoubleUpDown Grid.Row="1" Grid.Column="1" FormatString="F2" Value="{Binding LSDeltaMaxTravel}"
																					  HorizontalAlignment="Stretch" Margin="0,0,0,5"
																					  Minimum="0.0" Maximum="1.0" Increment="0.05"/>

																	<!-- Min Travel -->
																	<Label Grid.Row="2" Grid.Column="0" Content="{lex:Loc MinTravel}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
																	<xctk:DoubleUpDown Grid.Row="2" Grid.Column="1" FormatString="F2" Value="{Binding LSDeltaMinTravel}"
																					  HorizontalAlignment="Stretch" Margin="0,0,0,5"
																					  Minimum="0.0" Maximum="1.0" Increment="0.05"/>

																	<!-- Easing Duration -->
																	<Label Grid.Row="3" Grid.Column="0" Content="{lex:Loc EasingDuration}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
																	<DockPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,5">
																		<TextBlock Text="{lex:Loc SecondsUnit}" DockPanel.Dock="Right" FontSize="10" 
																				  Margin="5,0,0,0" VerticalAlignment="Center"/>
																		<xctk:DoubleUpDown FormatString="F2" Value="{Binding LSDeltaEasingDuration}"
																						  HorizontalAlignment="Stretch"
																						  Minimum="0.0" Maximum="600.0" Increment="0.1"/>
																	</DockPanel>

																	<!-- Min Factor -->
																	<Label Grid.Row="4" Grid.Column="0" Content="{lex:Loc MinFactor}" ContentStringFormat="{}{0}:" VerticalAlignment="Center"/>
																	<xctk:DoubleUpDown Grid.Row="4" Grid.Column="1" FormatString="F2" Value="{Binding LSDeltaMinFactor}"
																					  HorizontalAlignment="Stretch"
																					  Minimum="1.0" Maximum="10.0" Increment="0.1"/>
																</Grid>
															</Expander>
														</StackPanel>
													</GroupBox>
												</Grid>
											</StackPanel>
										</TabItem>

										<!-- FlickStick Tab -->
										<TabItem Header="{lex:Loc FlickStick}" Visibility="Collapsed">
											<StackPanel Margin="0,5,0,0">
												<!-- 统一的外部Grid - FlickStick Tab内的所有控件 -->
												<Grid>
													<Grid.RowDefinitions>
														<RowDefinition Height="Auto"/>
														<RowDefinition Height="Auto"/>
														<RowDefinition Height="Auto"/>
														<RowDefinition Height="Auto"/>
													</Grid.RowDefinitions>
													<Grid.ColumnDefinitions>
														<ColumnDefinition Width="{StaticResource AxisConfig_LSRS_1_Width}" MinWidth="{StaticResource AxisConfig_LSRS_1_MinWidth}"/>
														<ColumnDefinition Width="{StaticResource AxisConfig_LSRS_2_Width}"/>
													</Grid.ColumnDefinitions>
													
													<!-- Real World Calibration -->
													<Label Grid.Row="0" Grid.Column="0" Content="{lex:Loc RealWorldCalibration}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
													<xctk:DoubleUpDown Grid.Row="0" Grid.Column="1" Value="{Binding LSFlickRWC,UpdateSourceTrigger=LostFocus}" 
																	  FormatString="F2" HorizontalAlignment="Stretch" Margin="0,0,0,5"
																	  Maximum="200.0" Minimum="1.0" Increment="1.0"/>

													<!-- Flick Threshold -->
													<Label Grid.Row="1" Grid.Column="0" Content="{lex:Loc FlickThreshold}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
													<xctk:DoubleUpDown Grid.Row="1" Grid.Column="1" Value="{Binding LSFlickThreshold,UpdateSourceTrigger=LostFocus}" 
																	  FormatString="F2" HorizontalAlignment="Stretch" Margin="0,0,0,5"
																	  Maximum="1.0" Minimum="0.0" Increment="0.1"/>

													<!-- Flick Time -->
													<Label Grid.Row="2" Grid.Column="0" Content="{lex:Loc FlickTime}" ContentStringFormat="{}{0}:" VerticalAlignment="Center" Margin="0,0,0,5"/>
													<DockPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,5">
														<TextBlock Text="sec." DockPanel.Dock="Right" FontSize="10" Margin="5,0,0,0" VerticalAlignment="Center"/>
														<xctk:DoubleUpDown Value="{Binding LSFlickTime,UpdateSourceTrigger=LostFocus}" 
																		  FormatString="F2" HorizontalAlignment="Stretch"
																		  Maximum="10.0" Minimum="0.01" Increment="0.1"/>
													</DockPanel>

													<!-- Min Angle Threshold -->
													<Label Grid.Row="3" Grid.Column="0" Content="{lex:Loc MinAngleThreshold}" ContentStringFormat="{}{0}:" VerticalAlignment="Center"/>
													<DockPanel Grid.Row="3" Grid.Column="1">
														<TextBlock Text="&#xb0;" DockPanel.Dock="Right" FontSize="18" Margin="5,0,0,0" VerticalAlignment="Center"/>
														<xctk:DoubleUpDown Value="{Binding LSMinAngleThreshold,UpdateSourceTrigger=LostFocus}" 
																		  FormatString="F2" HorizontalAlignment="Stretch"
																		  Maximum="180.0" Minimum="0.0" Increment="0.5"/>
													</DockPanel>
												</Grid>
											</StackPanel>
										</TabItem>
									</TabControl>
								</Grid>
							</GroupBox>

							<!-- 中间间距列 -->
							<Grid Grid.Column="1"/>

							<!-- RS 列 -->
							<GroupBox Grid.Column="2" Header="RS" Margin="0,0,0,10">
								<Grid>
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto"/>
										<RowDefinition Height="Auto"/>
									</Grid.RowDefinitions>
									
									<!-- Output Mode 行 - 固定在顶部 -->
									<Grid Grid.Row="0" Margin="0,0,0,5">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="Auto"/>
											<ColumnDefinition Width="*"/>
										</Grid.ColumnDefinitions>
										<Label Content="{lex:Loc OutputMode}" VerticalAlignment="Center"/>
										<ComboBox Grid.Column="1" SelectedIndex="{Binding RSOutputIndex,FallbackValue='0'}" 
												  HorizontalAlignment="Left"  MinWidth="80" MaxWidth="160" VerticalContentAlignment="Center">
											<ComboBoxItem Content="{lex:Loc None}" />
											<ComboBoxItem Content="{lex:Loc Controls}" />
											<ComboBoxItem Content="{lex:Loc FlickStick}" />
										</ComboBox>
									</Grid>

									<!-- TabControl 占据剩余空间并自动适应高度 -->
									<TabControl Grid.Row="1" SelectedIndex="{Binding RSOutputIndex,Mode=OneWay,FallbackValue='0'}" 
												BorderBrush="{x:Null}" Padding="0" Margin="0,5,0,0"
												VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
										<TabItem Header="{lex:Loc None}" Visibility="Collapsed" />
										
										<!-- Controls Tab -->
										<TabItem Header="{lex:Loc Controls}" Visibility="Collapsed">
											<StackPanel Margin="0,0,5,0">
												<!-- DeadZone Type 行 -->
												<Grid Margin="0,0,0,5">
													<Grid.ColumnDefinitions>
														<ColumnDefinition Width="Auto"/>
														<ColumnDefinition Width="*"/>
													</Grid.ColumnDefinitions>
													<Label Content="{lex:Loc DeadZoneType}" VerticalAlignment="Center"/>
													<ComboBox Grid.Column="1" SelectedIndex="{Binding RSDeadTypeIndex,FallbackValue='0'}" 
															  HorizontalAlignment="Left"  MinWidth="80" MaxWidth="160" VerticalContentAlignment="Center">
														<ComboBoxItem Content="{lex:Loc Radial}" />
														<ComboBoxItem Content="{lex:Loc Axial}" />
													</ComboBox>
												</Grid>

												<!-- DeadZone Type specific controls (Radial/Axial) -->
												<TabControl SelectedIndex="{Binding RSDeadTypeIndex,Mode=OneWay,FallbackValue='0'}" 
															BorderBrush="{x:Null}" Padding="0" Margin="0,5,0,5">
													<TabItem Header="Radial" Visibility="Collapsed">
														<StackPanel>
															<!-- 统一的外部Grid - Radial Tab内的所有控件 -->
															<Grid>
																<Grid.RowDefinitions>
																	<RowDefinition Height="Auto"/>
																	<RowDefinition Height="Auto"/>
																	<RowDefinition Height="Auto"/>
																	<RowDefinition Height="Auto"/>
																	<RowDefinition Height="Auto"/>
																	<RowDefinition Height="Auto"/>
																</Grid.RowDefinitions>
																<Grid.ColumnDefinitions>
