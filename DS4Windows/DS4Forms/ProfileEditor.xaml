											  IsEnabled="{Binding DInputOnly, Converter={StaticResource InverseBoolConverter}}" 
											  MinWidth="140" ToolTip="{lex:Loc OutContNotice}" VerticalAlignment="Center"
											  VerticalContentAlignment="Center">
										<ComboBoxItem Content="Xbox 360" VerticalContentAlignment="Center"/>
										<ComboBoxItem Content="DualShock 4" VerticalContentAlignment="Center"/>
									</ComboBox>
								</StackPanel>
								<CheckBox Content="{lex:Loc DisableVirtualController}" IsChecked="{Binding DInputOnly}"
										  ToolTip="{lex:Loc DisableVirtualControllerTip}" VerticalAlignment="Center"/>
