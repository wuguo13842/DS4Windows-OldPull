						<GroupBox Header="{lex:Loc VirtualControllerSettings}" MinHeight="50" Margin="4,4,4,0" Padding="0,4,0,4">
							<StackPanel>
								<StackPanel Orientation="Horizontal" Margin="0,0,0,5">
