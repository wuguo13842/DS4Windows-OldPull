									<Label Content="{lex:Loc ProfileEditor.VirtualDS4TrigOutput}" ContentStringFormat="{}{0}:" Margin="0,0,8,0" VerticalAlignment="Center"/>
									<ComboBox ItemsSource="{Binding Path=OutputDS4TriggerModeOptions}"
											  DisplayMemberPath="DisplayName" SelectedValuePath="ChoiceValue" 
											  SelectedValue="{Binding OutputDS4TriggerMode}" VerticalAlignment="Center"
											  VerticalContentAlignment="Center"/>
