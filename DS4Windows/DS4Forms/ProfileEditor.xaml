											   VerticalAlignment="Center" Margin="5,0,0,0"/>
									</StackPanel>

									<StackPanel Orientation="Horizontal" Margin="0,0,0,8">
										<Button x:Name="gyroSwipeLeftBtn" Content="{lex:Loc SwipeLeft}" Width="100" 
												Tag="{Binding GyroSwipeLeft, Source={StaticResource controlIndexCheck}}" Click="GyroSwipeControlsBtn_Click" 
												VerticalAlignment="Center" MinHeight="24"/>
										<Label x:Name="gyroSwipeLeftLb" Content="{Binding MappingName,FallbackValue=Unassigned}" 
											   VerticalAlignment="Center" Margin="5,0,0,0"/>
									</StackPanel>

									<StackPanel Orientation="Horizontal" Margin="0,0,0,8">
