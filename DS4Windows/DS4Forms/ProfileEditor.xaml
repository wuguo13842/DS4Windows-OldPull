											Click="RumbleTestBtn_Click" VerticalAlignment="Center" VerticalContentAlignment="Center"/>
									<Button x:Name="lightRumbleTestBtn" Content="{lex:Loc TestLight}" Margin="10,0,0,0" 
											Click="RumbleTestBtn_Click" VerticalAlignment="Center" VerticalContentAlignment="Center"/>
								</UniformGrid>

								<CheckBox Content="{lex:Loc InverseMotors}" IsChecked="{Binding InverseRumbleMotors}" 
										  VerticalAlignment="Center" Margin="0,5,0,0"/>

