										<DockPanel LastChildFill="False">
											<Label Content="{lex:Loc SecondsUnit}" DockPanel.Dock="Right" VerticalAlignment="Center"/>
											<xctk:IntegerUpDown x:Name="RumbleAutostopTimeIUD" d:IsHidden="True" Value="{Binding RumbleAutostopTime}" 
																Minimum="0" Maximum="3600" Increment="1" MinWidth="50" 
																ToolTip="{lex:Loc RumbleMaxSecsTip}"
																VerticalAlignment="Center" VerticalContentAlignment="Center"/>
