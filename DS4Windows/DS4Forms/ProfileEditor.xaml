							<xctk:IntegerUpDown d:IsHidden="True" MinWidth="50" Height="20"
												Value="{Binding ButtonMouseVerticalScale,FallbackValue='100'}"
												Minimum="0" Maximum="500" Increment="10" Margin="10,0,0,0"
												VerticalAlignment="Center" VerticalContentAlignment="Center"/>
							<Label Content="%" VerticalContentAlignment="Center" Margin="4,0,0,0" VerticalAlignment="Center"/>
						</StackPanel>

						<!-- Mouse Offset -->
						<StackPanel Orientation="Horizontal">
							<Label Content="{lex:Loc MouseOffset}" VerticalAlignment="Center" />
							<xctk:DoubleUpDown d:IsHidden="True" MinWidth="50" FormatString="F3" DefaultValue="0" Minimum="0" Maximum="100"
											   Value="{Binding ButtonMouseOffset,FallbackValue=0,UpdateSourceTrigger=LostFocus}"
											   VerticalAlignment="Center" VerticalContentAlignment="Center"/>
							<Label Content="%" VerticalAlignment="Center" Margin="2,0,0,0"/>
							<TextBlock Text="{Binding MouseOffsetSpeed,Mode=OneWay,StringFormat='\{0:0.00} {lex:Loc PPSUnit}'}"
									   MinWidth="50" VerticalAlignment="Center" Margin="10,0,0,0" />
						</StackPanel>

						<!-- Additional Options -->
						<CheckBox Content="{lex:Loc MouseAcceleration}" IsChecked="{Binding MouseAcceleration}" 
								  Margin="0,6,0,0" VerticalAlignment="Center"/>
						<CheckBox Content="{lex:Loc EnableTouchpadToggle}" IsChecked="{Binding EnableTouchpadToggle}" 
								  Margin="0,6,0,0" ToolTip="{lex:Loc EnableTouchToggleTip}" VerticalAlignment="Center"/>
						<CheckBox Content="{lex:Loc EnableOutputDataToDS4}" IsChecked="{Binding EnableOutputDataToDS4}" 
								  Margin="0,6,0,0" ToolTip="{lex:Loc EnableOutputDataToDS4Tip}" VerticalAlignment="Center"/>

						<!-- Launch Program -->
						<StackPanel Orientation="Horizontal" Margin="0,6,0,0">
							<CheckBox x:Name="launchProgCk" Content="{lex:Loc LaunchProgramWithProfile}" 
									  IsChecked="{Binding LaunchProgramExists}" IsEnabled="{Binding LaunchProgramExists}"
									  VerticalAlignment="Center"/>
							<Button x:Name="launchProgBrowseBtn" Click="LaunchProgBrowseBtn_Click" Width="80" Height="30" 
									Margin="20,0,0,0" VerticalAlignment="Center" VerticalContentAlignment="Center">
								<Button.Content>
									<PriorityBinding>
										<Binding Path="LaunchProgramName" />
										<lex:BLoc Key="Browse" />
									</PriorityBinding>
								</Button.Content>
							</Button>
							<Button x:Name="launchProgIconBtn" Width="20" Height="20" Margin="20,0,0,0" 
									Focusable="False" VerticalAlignment="Center">
								<Button.Background>
									<ImageBrush ImageSource="{Binding LaunchProgramIcon}" />
								</Button.Background>
							</Button>
						</StackPanel>

						<!-- Idle Disconnect -->
						<StackPanel Orientation="Horizontal" Height="30" Margin="0,6,0,0">
							<CheckBox Content="{lex:Loc IdleDisconnect}" VerticalAlignment="Center" IsChecked="{Binding IdleDisconnectExists}" />
							<xctk:IntegerUpDown x:Name="idleDisconnectUD" d:IsHidden="True" Value="{Binding IdleDisconnect,FallbackValue=5}"
												IsEnabled="{Binding IdleDisconnectExists}" MinWidth="50" Height="20" 
												Minimum="0" Maximum="60" Margin="10,0,0,0"
												VerticalAlignment="Center" VerticalContentAlignment="Center"/>
							<Label Content="{lex:Loc MinutesUnit}" VerticalAlignment="Center" Margin="5,0,0,0"/>
						</StackPanel>

						<!-- BT Poll Rate -->
						<StackPanel Orientation="Horizontal" Margin="0,6,0,0">
							<Label Content="{lex:Loc DS4BTPollRate}" ContentStringFormat="{}{0}:" ToolTip="{lex:Loc BtPollRateTip}" 
								   VerticalAlignment="Center" />
							<ComboBox x:Name="btPollRateCombo" SelectedIndex="{Binding TempBTPollRateIndex,FallbackValue=4}" 
									  MinWidth="140" ToolTip="{lex:Loc BtPollRateTip}" Margin="8,0,0,0"
									  VerticalAlignment="Center" VerticalContentAlignment="Center">
								<ComboBoxItem Content="Max (1 ms)" />
								<ComboBoxItem Content="1000 Hz (1 ms)" />
								<ComboBoxItem Content="500 Hz (2 ms)" />
								<ComboBoxItem Content="333 Hz (3 ms)" />
								<ComboBoxItem Content="250 Hz (4 ms)" />
								<ComboBoxItem Content="200 Hz (5 ms)" />
								<ComboBoxItem Content="166 Hz (6 ms)" />
								<ComboBoxItem Content="142 Hz (7 ms)" />
								<ComboBoxItem Content="125 Hz (8 ms)" />
								<ComboBoxItem Content="111 Hz (9 ms)" />
								<ComboBoxItem Content="100 Hz (10 ms)" />
								<ComboBoxItem Content="90 Hz (11 ms)" />
								<ComboBoxItem Content="83 Hz (12 ms)" />
								<ComboBoxItem Content="76 Hz (13 ms)" />
								<ComboBoxItem Content="71 Hz (14 ms)" />
								<ComboBoxItem Content="66 Hz (15 ms)" />
								<ComboBoxItem Content="62 Hz (16 ms)" />
							</ComboBox>
						</StackPanel>

						<!-- Absolute Mouse Options -->
						<GroupBox Header="{lex:Loc AbsoluteMouseOptions}" Margin="0,8,0,0">
							<StackPanel Orientation="Vertical">
								<Expander IsExpanded="False" Header="{lex:Loc Settings}">
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition />
											<ColumnDefinition />
										</Grid.ColumnDefinitions>
										<Grid.RowDefinitions>
											<RowDefinition Height="Auto"/>
											<RowDefinition Height="Auto"/>
											<RowDefinition Height="Auto"/>
											<RowDefinition Height="Auto"/>
											<RowDefinition Height="Auto"/>
											<RowDefinition Height="Auto"/>
										</Grid.RowDefinitions>

										<!-- Width -->
										<Label Content="{lex:Loc Width}" ContentStringFormat="{}{0}:" Grid.Row="0" Grid.Column="0" 
											   VerticalAlignment="Center"/>
										<xctk:DoubleUpDown d:IsHidden="True" FormatString="F2" Value="{Binding AbsWidth}"
														  MinWidth="100" Minimum="0.0" Maximum="1.0" Increment="0.05"
														  Margin="{StaticResource spaceMargin}" Grid.Row="0" Grid.Column="1"
														  VerticalAlignment="Center" VerticalContentAlignment="Center"/>

										<!-- Height -->
										<Label Content="{lex:Loc Height}" ContentStringFormat="{}{0}:" Grid.Row="1" Grid.Column="0" 
											   VerticalAlignment="Center"/>
										<xctk:DoubleUpDown d:IsHidden="True" FormatString="F2" Value="{Binding AbsHeight}"
														  MinWidth="100" Minimum="0.0" Maximum="1.0" Increment="0.05"
														  Margin="{StaticResource spaceMargin}" Grid.Row="1" Grid.Column="1"
														  VerticalAlignment="Center" VerticalContentAlignment="Center"/>

										<!-- X Center -->
										<Label Content="{lex:Loc XCenter}" ContentStringFormat="{}{0}:" Grid.Row="2" Grid.Column="0" 
											   VerticalAlignment="Center"/>
										<xctk:DoubleUpDown d:IsHidden="True" FormatString="F2" Value="{Binding AbsXCenter}"
														  MinWidth="100" Minimum="0.0" Maximum="1.0" Increment="0.05"
														  Margin="{StaticResource spaceMargin}" Grid.Row="2" Grid.Column="1"
														  VerticalAlignment="Center" VerticalContentAlignment="Center"/>

										<!-- Y Center -->
										<Label Content="{lex:Loc YCenter}" ContentStringFormat="{}{0}:" Grid.Row="3" Grid.Column="0" 
											   VerticalAlignment="Center"/>
										<xctk:DoubleUpDown d:IsHidden="True" FormatString="F2" Value="{Binding AbsYCenter}"
														  MinWidth="100" Minimum="0.0" Maximum="1.0" Increment="0.05"
														  Margin="{StaticResource spaceMargin}" Grid.Row="3" Grid.Column="1"
														  VerticalAlignment="Center" VerticalContentAlignment="Center"/>

										<!-- Anti Radius -->
										<Label Content="{lex:Loc AntiRadius}" ContentStringFormat="{}{0}:" Grid.Row="4" Grid.Column="0" 
											   VerticalAlignment="Center"/>
										<DockPanel Grid.Row="4" Grid.Column="1" LastChildFill="True">
											<TextBlock Text="%" DockPanel.Dock="Right" 
													   Margin="{StaticResource spaceMargin}" VerticalAlignment="Center"/>
											<xctk:DoubleUpDown d:IsHidden="True" FormatString="F2" Value="{Binding AbsAntiRadius}"
															  MinWidth="100" Minimum="0.0" Maximum="1.0" Increment="0.05"
															  Margin="{StaticResource spaceMargin}" 
															  VerticalAlignment="Center" VerticalContentAlignment="Center"/>
										</DockPanel>

										<!-- Snap to Center -->
										<Label Content="{lex:Loc SnapToCenter}" ContentStringFormat="{}{0}:" Grid.Row="5" Grid.Column="0" 
											   VerticalAlignment="Center"/>
										<CheckBox IsChecked="{Binding AbsSnapCenter}" MinWidth="50" Grid.Row="5" Grid.Column="1" 
												  VerticalAlignment="Center"/>
									</Grid>
								</Expander>
							</StackPanel>
						</GroupBox>
					</StackPanel>
				</ScrollViewer>
			</TabItem>
       </TabControl>
    </DockPanel>
</UserControl>
