									<StackPanel Orientation="Horizontal" Margin="0,8,0,8">
										<Button x:Name="gyroCalBtn2" Content="{lex:Loc GyroCalibration}" Width="100" 
												Click="GyroCalibration_Click" VerticalAlignment="Center" MinHeight="24"/>
									</StackPanel>
								</StackPanel>
							</TabItem>

