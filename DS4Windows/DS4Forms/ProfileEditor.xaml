										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>
									<CheckBox Grid.Column="0" Content="{lex:Loc LowBatteryNotify}" 
											  IsChecked="{Binding EnableLowBatteryNotification}"
											  ToolTip="{lex:Loc LowBatteryNotifyTooltip}" 
											  VerticalAlignment="Center"/>
									<TextBlock Grid.Column="1" Text="{lex:Loc ThresholdPrefix}" 
											   Margin="10,0,0,0" VerticalAlignment="Center"/>
									<TextBlock Grid.Column="2" Text="{Binding FlashAt, StringFormat={}{0}%}" 
											   VerticalAlignment="Center" Margin="4,0,0,0"/>
									<TextBlock Grid.Column="3" Text="{lex:Loc ThresholdSuffix}" 
											   VerticalAlignment="Center" Margin="4,0,0,0"/>
								</Grid>

								<!-- 第四行：充电相关控件 -->
								<Grid Grid.Row="3" Margin="0,0,0,10">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="Auto"/>
										<ColumnDefinition Width="Auto"/>
										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>
									<Label Grid.Column="0" Content="{lex:Loc WhileChargingLabel}" 
										   VerticalAlignment="Center"/>
									<ComboBox Grid.Column="1" Margin="8,0,0,0" 
											  SelectedIndex="{Binding ChargingType,FallbackValue=0}"
											  VerticalAlignment="Center">
										<ComboBoxItem Content="{lex:Loc ChargingNormal}" />
										<ComboBoxItem Content="{lex:Loc ChargingPulse}" />
										<ComboBoxItem Content="{lex:Loc ChargingRainbow}" />
										<ComboBoxItem Content="{lex:Loc ChargingColor}" />
									</ComboBox>
									<Button x:Name="chargingColorBtn" Grid.Column="2" Width="20" Height="20" 
											Background="{Binding ChargingColor,FallbackValue=Blue}"
											Visibility="{Binding ChargingColorVisible}" 
											Click="ChargingColorBtn_Click" Margin="20,0,0,0"
											VerticalAlignment="Center"/>
								</Grid>

								<!-- 第五行：ColorByBattery -->
								<CheckBox x:Name="colorByBatteryPerCk" Grid.Row="4" 
										  Content="{lex:Loc ColorByBattery}" 
										  IsChecked="{Binding ColorBatteryPercent}"
										  ToolTip="{lex:Loc LightByBatteryTip}" 
										  Click="ColorByBatteryPerCk_Click" 
										  Margin="0,0,0,10" HorizontalAlignment="Left"/>

								<!-- 第六行：Rainbow 相关控件（使用Grid保持对齐） -->
								<Grid Grid.Row="5" Margin="0,0,0,0">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="Auto"/>
										<ColumnDefinition Width="Auto"/>
										<ColumnDefinition Width="Auto"/>
										<ColumnDefinition Width="*"/> <!-- 最后一列占用剩余空间 -->
									</Grid.ColumnDefinitions>
									
									<!-- 彩虹按钮 -->
									<Button x:Name="rainbowBtn" Grid.Column="0" Height="20" Width="20" 
											ToolTip="{lex:Loc Resources:AlwaysRainbow}" Click="RainbowBtn_Click"
											VerticalAlignment="Center">
										<Button.Content>
											<Image Source="{Binding Source={StaticResource resourcesPaths}, Path=DS4LightbarPNG}" />
										</Button.Content>
									</Button>
									
									<!-- 整数调节 -->
									<xctk:IntegerUpDown Grid.Column="1" MinWidth="30" Height="30" 
														Minimum="0" Maximum="60" Increment="1" 
														Margin="8,0,0,0" VerticalAlignment="Center"
														Value="{Binding Rainbow,FallbackValue=5}" 
														IsEnabled="{Binding RainbowExists}" />
									
									<!-- 标签 -->
									<Label Grid.Column="2" Content="{lex:Loc SecsPerCycle}" Padding="0" 
										   Margin="8,0,0,0" VerticalAlignment="Center"/>
									
									<!-- 右侧滑块与百分比显示区域（使用嵌套Grid） -->
									<Grid Grid.Column="3" Margin="8,0,0,0">
										<Grid.RowDefinitions>
											<RowDefinition Height="Auto"/>
											<RowDefinition Height="Auto"/>
										</Grid.RowDefinitions>
										
										<!-- 第一行：百分比文本 -->
										<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,2">
											<TextBlock Text="{lex:Loc MaxLightPrefix}" VerticalAlignment="Center"/>
											<TextBlock Text="{Binding MaxSatRainbow, FallbackValue=100, StringFormat={}{0:F0}%}" 
													   Margin="4,0,0,0" VerticalAlignment="Center"/>
										</StackPanel>
										
										<!-- 第二行：滑块 - 水平拉伸对齐 -->
										<Slider Grid.Row="1" Value="{Binding MaxSatRainbow,FallbackValue=100}" 
												Minimum="0" Maximum="100" Width="100" 
												IsEnabled="{Binding RainbowExists}" 
												HorizontalAlignment="Left"/>
									</Grid>
								</Grid>
							</Grid>
						</TabItem>

						<!-- Passthru 标签页 -->
						<TabItem Header="{lex:Loc Passthru}" Visibility="Collapsed">
							<Grid>
								<TextBlock Foreground="Red" Text="{lex:Loc DS4LightbarPassthruDisabled}" TextWrapping="Wrap"
										   Visibility="{Binding UsingMinViGEm173333, Mode=OneWay, Converter={StaticResource InvertBoolToVisibilityConverter}}"/>
							</Grid>
						</TabItem>
					</TabControl>
				</Grid>
			</TabItem>

			<TabItem Header="{lex:Loc Touchpad}">
				<TabItem.Resources>
					<Thickness x:Key="spaceMargin" Bottom="8" />
				</TabItem.Resources>
				
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="4">
						<!-- Output Mode 选择行 - 保持原有布局 -->
						<StackPanel Orientation="Horizontal" Margin="{StaticResource spaceMargin}">
							<Label Content="{lex:Loc OutputMode}" VerticalAlignment="Center"/>
							<ComboBox x:Name="touchpadOutModeCombo" Width="160" 
									  SelectedIndex="{Binding TouchpadOutputIndex, FallbackValue='0'}" 
									  VerticalContentAlignment="Center" Margin="10,0,0,0"
									  VerticalAlignment="Center">
								<ComboBoxItem Content="{lex:Loc Mouse}"/>
								<ComboBoxItem Content="{lex:Loc Controls}"/>
								<ComboBoxItem Content="{lex:Loc MouseJoystick}"/>
								<ComboBoxItem Content="{lex:Loc AbsoluteMouse}"/>
								<ComboBoxItem Content="{lex:Loc Passthru}"/>
							</ComboBox>
						</StackPanel>

						<TabControl x:Name="touchOutputTabControl" 
									SelectedIndex="{Binding TouchpadOutputIndex, FallbackValue='0'}" 
									BorderBrush="{x:Null}" Margin="{StaticResource spaceMargin}">
							
							<!-- Mouse 标签页 -->
							<TabItem Header="{lex:Loc Mouse}" Visibility="Collapsed">
								<StackPanel>
									<!-- 保持原有的 Grid 布局不变，只替换文本 -->
									<Grid>
										<Grid.RowDefinitions>
											<RowDefinition />
											<RowDefinition />
											<RowDefinition />
											<RowDefinition />
										</Grid.RowDefinitions>
										<Grid.ColumnDefinitions>
											<!-- 第一列：自动适应内容宽度 -->
											<ColumnDefinition Width="Auto"/>
											<!-- 固定20像素间距 -->
											<ColumnDefinition Width="20"/>
											<!-- 第二列：占据剩余空间 -->
											<ColumnDefinition Width="*"/>
										</Grid.ColumnDefinitions>

										<!-- 行1：Slide 和 Jitter -->
										<StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
											<CheckBox Content="{lex:Loc TouchSlide}" 
													  IsChecked="{Binding TouchSenExists}" 
													  VerticalAlignment="Center"/>
											<xctk:IntegerUpDown d:IsHidden="True" MinWidth="80" Width="80" Height="20" 
																Maximum="500" Value="{Binding TouchSens}" 
																IsEnabled="{Binding TouchSenExists}" 
																Margin="8,0,0,0" 
																VerticalAlignment="Center"/>
										</StackPanel>
										
										<!-- 第二列是20像素的空列，用于保持间距 -->
										
										<CheckBox Grid.Row="0" Grid.Column="2" 
												  Content="{lex:Loc JitterCompensation}" 
												  IsChecked="{Binding TouchJitter}" 
												  VerticalAlignment="Center"
												  ToolTip="{lex:Loc TouchpadJitterCompTooltip}" 
												  Margin="0,0,0,8"/>

										<!-- 行2：Tap 和 Double Tap -->
										<StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="0" Margin="0,0,0,8">
											<CheckBox Content="{lex:Loc TouchTap}" 
													  IsChecked="{Binding TouchTapExists}" 
													  VerticalAlignment="Center" 
													  ToolTip="{lex:Loc TouchpadTapTooltip}"/>
											<xctk:IntegerUpDown Value="{Binding TouchTap}" d:IsHidden="True" 
																MinWidth="80" Width="80" Height="20" 
																IsEnabled="{Binding TouchTapExists}"
																ToolTip="{lex:Loc TouchpadTapTooltip}"
																Margin="8,0,0,0" 
																VerticalAlignment="Center"/>
										</StackPanel>
										
										<CheckBox Grid.Row="1" Grid.Column="2" 
												  Content="{lex:Loc DoubleTap}" 
												  IsChecked="{Binding TouchDoubleTap}" 
												  VerticalAlignment="Center"
												  ToolTip="{lex:Loc TapAndHold}" 
												  Margin="0,0,0,8"/>

										<!-- 行3：Scroll 和 Lower Right as RMB -->
										<StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="0" Margin="0,0,0,8">
											<CheckBox Content="{lex:Loc TouchScroll}" 
													  IsChecked="{Binding TouchScrollExists}" 
													  VerticalAlignment="Center" 
													  ToolTip="{lex:Loc TouchpadSlideTooltip}"/>
											<xctk:IntegerUpDown Value="{Binding TouchScroll}" d:IsHidden="True" 
																MinWidth="80" Width="80" Height="20" 
																IsEnabled="{Binding TouchScrollExists}"
																ToolTip="{lex:Loc TouchpadSlideTooltip}"
																Margin="8,0,0,0" 
																VerticalAlignment="Center"/>
										</StackPanel>
										
										<CheckBox Grid.Row="2" Grid.Column="2" 
												  Content="{lex:Loc LowerRightAsRMB}" 
												  IsChecked="{Binding LowerRightTouchRMB}" 
												  VerticalAlignment="Center"
												  ToolTip="{lex:Loc BestUsedRightSide}" 
												  Margin="0,0,0,8"/>
										
									</Grid>

									<!-- Passthru Click Action -->
									<CheckBox Grid.Row="3" Grid.Column="0" 
											  Content="{lex:Loc PassthruClickAction}" 
											  IsChecked="{Binding TouchpadClickPassthru}" 
											  VerticalAlignment="Center" 
											  Margin="0,0,0,0"/>

									<!-- Start with Slide/Scroll Off -->
									<CheckBox Content="{lex:Loc StartSlideScrollOff}" 
											  IsChecked="{Binding StartTouchpadOff}" 
											  VerticalAlignment="Center"
											  ToolTip="{lex:Loc TouchpadOffTip}" 
											  Margin="0,10,0,0"
									/>

									<!-- Rotation - 保持原有布局 -->
									<StackPanel Orientation="Horizontal" Margin="{StaticResource spaceMargin}">
										<Label Content="{lex:Loc RotationLabel}" 
											   ContentStringFormat="{}{0}:" 
											   VerticalAlignment="Center"/>
										<xctk:DoubleUpDown d:IsHidden="True" MinWidth="80" Height="20" 
														   Minimum="-180" Maximum="180" Increment="1" 
														   FormatString="F0" 
														   Value="{Binding TouchRelMouseRotation,FallbackValue='0'}"
														   ToolTip="{lex:Loc TouchpadRotationTooltip}"
														   Margin="8,0,0,0" 
														   VerticalAlignment="Center"/>
										<TextBlock Text="&#xb0;" FontSize="18" 
												   Margin="4,0,0,0" VerticalAlignment="Center"/>
									</StackPanel>

									<!-- Min Threshold -->
									<StackPanel Orientation="Horizontal" Margin="{StaticResource spaceMargin}">
										<Label Content="{lex:Loc MinThreshold}" 
											   ContentStringFormat="{}{0}:" 
											   VerticalAlignment="Center"/>
										<xctk:DoubleUpDown d:IsHidden="True" MinWidth="80" Height="20" 
														   Minimum="1.0" Maximum="40.0" Increment="1.0" 
														   FormatString="F1" 
														   Value="{Binding TouchRelMouseMinThreshold,FallbackValue='1.0'}"
														   ToolTip="{lex:Loc TouchpadMinThresholdTooltip}"
														   Margin="8,0,0,0" 
														   VerticalAlignment="Center"/>
									</StackPanel>

									<!-- Trackball -->
									<StackPanel Orientation="Horizontal" Height="20" Margin="{StaticResource spaceMargin}">
										<CheckBox Content="{lex:Loc Trackball}" 
												  IsChecked="{Binding TouchTrackball}" 
												  VerticalAlignment="Center" 
												  ToolTip="{lex:Loc TouchpadTrackballEnableTooltip}"/>
										<Label Content="{lex:Loc FrictionLabel}" Padding="0" 
											   Margin="20,0,5,0" VerticalAlignment="Center"/>
										<xctk:DoubleUpDown x:Name="frictionUD" d:IsHidden="True" MinWidth="80" 
														   IsEnabled="{Binding TouchTrackball}" 
														   Minimum="0.1" Maximum="20.0"
														   Value="{Binding TouchTrackballFriction,FallbackValue='10'}" 
														   ValueChanged="FrictionUD_ValueChanged"
														   ToolTip="{lex:Loc TouchpadTrackballFrictionTooltip}"
														   Margin="8,0,0,0" 
														   VerticalAlignment="Center"/>
									</StackPanel>

									<!-- Invert ComboBox -->
									<StackPanel Orientation="Horizontal" Margin="{StaticResource spaceMargin}">
										<Label Content="{lex:Loc InvertLabel}" Padding="0" 
											   HorizontalAlignment="Center" VerticalAlignment="Center"/>
										<ComboBox MinWidth="160" SelectedIndex="{Binding TouchInvertIndex}" 
												  Margin="20,0,0,0"
												  VerticalAlignment="Center"
												  VerticalContentAlignment="Center">
											<ComboBoxItem Content="{lex:Loc None}" />
											<ComboBoxItem Content="X" />
											<ComboBoxItem Content="Y" />
											<ComboBoxItem Content="X+Y" />
										</ComboBox>
									</StackPanel>

									<!-- Disable Invert Button -->
									<StackPanel Orientation="Horizontal" Margin="{StaticResource spaceMargin}">
										<Label Content="{lex:Loc DisableInvertLabel}" Padding="0" 
											   HorizontalAlignment="Center" VerticalAlignment="Center"/>
										<Button x:Name="touchDisInvertBtn" MinWidth="160" Height="22" 
												Content="{Binding TouchDisInvertString,FallbackValue=None}" 
												Click="TouchDisInvertBtn_Click" 
												Margin="20,0,0,0"
												VerticalAlignment="Center">
											<!-- ContextMenu 中的 MenuItem 也需要本地化 -->
											<Button.ContextMenu>
												<ContextMenu>
													<MenuItem Header="{lex:Loc Cross}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc Circle}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc Square}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc Triangle}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="L1" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="L2" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="R1" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="R2" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc Up}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc Down}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc Left}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc Right}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="L3" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="R3" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc FingerOnTouchpad}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc TwoFingersOnTouchpad}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc Options}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc Share}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc PS}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc TouchpadClick}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc Mute}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc SideL}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc SideR}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<!-- DualSense Edge extra buttons -->
													<MenuItem Header="{lex:Loc FunctionLeft}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc FunctionRight}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc BottomLeftPaddle}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
													<MenuItem Header="{lex:Loc BottomRightPaddle}" IsCheckable="True" Click="TouchDisInvertMenuItem_Click" />
												</ContextMenu>
											</Button.ContextMenu>
										</Button>
									</StackPanel>

									<ContentControl x:Name="touchContentControl1" MinWidth="400" HorizontalAlignment="Left" />
								</StackPanel>
							</TabItem>

							<!-- Controls 标签页 -->
							<TabItem Header="{lex:Loc Controls}" Visibility="Collapsed">
								<StackPanel>
									<!-- Swipe Up -->
									<StackPanel Orientation="Horizontal" Margin="5,0,0,0">
										<Button x:Name="swipeUpBtn" Content="{lex:Loc SwipeUp}" MinWidth="100" 
												Tag="{Binding SwipeUp, Source={StaticResource controlIndexCheck}}" 
												Click="SwipeControlsButton_Click"
												VerticalAlignment="Center"/>
										<Label x:Name="swipeUpLb" Content="{Binding MappingName,FallbackValue=Unassigned}"  
											   Margin="10,0,0,0" VerticalAlignment="Center"/>
									</StackPanel>
									
									<!-- Swipe Down -->
									<StackPanel Orientation="Horizontal" Margin="5,8,0,0">
										<Button x:Name="swipeDownBtn" Content="{lex:Loc SwipeDown}" MinWidth="100" 
												Tag="{Binding SwipeDown, Source={StaticResource controlIndexCheck}}" 
												Click="SwipeControlsButton_Click"
												VerticalAlignment="Center"/>
										<Label x:Name="swipeDownLb" Content="{Binding MappingName,FallbackValue=Unassigned}"  
											   Margin="10,0,0,0" VerticalAlignment="Center"/>
									</StackPanel>
									
									<!-- Swipe Left -->
									<StackPanel Orientation="Horizontal" Margin="5,8,0,0">
										<Button x:Name="swipeLeftBtn" Content="{lex:Loc SwipeLeft}" MinWidth="100" 
												Tag="{Binding SwipeLeft, Source={StaticResource controlIndexCheck}}" 
												Click="SwipeControlsButton_Click"
												VerticalAlignment="Center"/>
										<Label x:Name="swipeLeftLb" Content="{Binding MappingName,FallbackValue=Unassigned}"  
											   Margin="10,0,0,0" VerticalAlignment="Center"/>
									</StackPanel>
									
									<!-- Swipe Right -->
									<StackPanel Orientation="Horizontal" Margin="5,8,0,10">
										<Button x:Name="swipeRightBtn" Content="{lex:Loc SwipeRight}" MinWidth="100" 
												Tag="{Binding SwipeRight, Source={StaticResource controlIndexCheck}}" 
												Click="SwipeControlsButton_Click"
												VerticalAlignment="Center"/>
										<Label x:Name="swipeRightLb" Content="{Binding MappingName,FallbackValue=Unassigned}"  
											   Margin="10,0,0,0" VerticalAlignment="Center"/>
									</StackPanel>

									<CheckBox Content="{lex:Loc PassthruClickAction}" 
											  IsChecked="{Binding TouchpadClickPassthru}" 
											  VerticalAlignment="Center"
											  Margin="5,8,0,10"/>

									<ContentControl x:Name="touchContentControl2" MinWidth="400" 
													HorizontalAlignment="Left" Margin="5,8,0,0" />
								</StackPanel>
							</TabItem>

							<!-- MouseJoystick 标签页 - 只修改文本，保持原有 StackPanel 布局 -->
							<TabItem Header="{lex:Loc MouseJoystick}" Visibility="Collapsed">
								<StackPanel x:Name="touchMouseJoystickPanel">
									<!-- DeadZone and MaxZone -->
									<StackPanel Orientation="Horizontal" Margin="{StaticResource spaceMargin}">
										<Label Content="{lex:Loc DeadZone}" VerticalAlignment="Center"/>
										<xctk:IntegerUpDown d:IsHidden="True" Margin="8,0,0,0" 
															Value="{Binding TouchMouseStickDeadZone}" 
															MinWidth="60" 
															VerticalAlignment="Center"/>
										<Label Content="{lex:Loc MaxZone}" 
											   ContentStringFormat="{}{0}:" Margin="8,0,0,0" 
											   VerticalAlignment="Center"/>
										<xctk:IntegerUpDown d:IsHidden="True" Margin="8,0,0,0" 
															Value="{Binding TouchMouseStickMaxZone}" 
															MinWidth="60" Minimum="1" 
															VerticalAlignment="Center"/>
									</StackPanel>

									<!-- Output Stick -->
									<StackPanel Orientation="Horizontal" Margin="{StaticResource spaceMargin}">
										<Label Content="{lex:Loc OutputStickLabel}" VerticalAlignment="Center"/>
										<ComboBox SelectedIndex="{Binding TouchMouseStickOutputStick}" 
												  Margin="8,0,0,0" 
												  VerticalAlignment="Center"
												  VerticalContentAlignment="Center">
											<ComboBoxItem Content="{lex:Loc None}" />
											<ComboBoxItem Content="{lex:Loc LeftStick}" />
											<ComboBoxItem Content="{lex:Loc RightStick}" />
										</ComboBox>
									</StackPanel>

									<!-- Output Axes -->
									<StackPanel Orientation="Horizontal" Margin="{StaticResource spaceMargin}">
										<Label Content="{lex:Loc OutputAxesLabel}" VerticalAlignment="Center"/>
										<ComboBox SelectedIndex="{Binding TouchMouseStickOutputAxes}" 
												  Margin="8,0,0,0" 
												  VerticalAlignment="Center"
												  VerticalContentAlignment="Center">
											<ComboBoxItem Content="{lex:Loc None}" />
											<ComboBoxItem Content="{lex:Loc HorizontalAndVertical}" />
											<ComboBoxItem Content="{lex:Loc HorizontalOnly}" />
											<ComboBoxItem Content="{lex:Loc VerticalOnly}" />
										</ComboBox>
									</StackPanel>

									<!-- Minimum X and Y -->
									<StackPanel Orientation="Horizontal" Height="30" Margin="{StaticResource spaceMargin}">
										<Label Content="{lex:Loc MinimumXLabel}" VerticalAlignment="Center"/>
										<xctk:DoubleUpDown d:IsHidden="True" Margin="8,0,0,0" 
														   Value="{Binding TouchMouseStickAntiDeadX}" 
														   MinWidth="60"
														   FormatString="F0" Minimum="0.0" Maximum="100.0" 
														   Increment="10.0" 
														   VerticalAlignment="Center"/>
										<Label Content="%" Margin="2,0,0,0" VerticalAlignment="Center"/>
										
										<Label Content="{lex:Loc MinimumYLabel}" Margin="8,0,0,0" 
											   VerticalAlignment="Center"/>
										<xctk:DoubleUpDown d:IsHidden="True" Margin="8,0,0,0" 
														   Value="{Binding TouchMouseStickAntiDeadY}" 
														   MinWidth="60"
														   FormatString="F0" Minimum="0.0" Maximum="100.0" 
														   Increment="10.0" 
														   VerticalAlignment="Center"/>
										<Label Content="%" Margin="2,0,0,0" VerticalAlignment="Center"/>
									</StackPanel>

									<!-- VerticalScale -->
									<StackPanel Orientation="Horizontal" Margin="{StaticResource spaceMargin}">
										<Label Content="{lex:Loc VerticalScale}" VerticalAlignment="Center"/>
										<xctk:IntegerUpDown d:IsHidden="True" Margin="8,0,0,0" 
															Value="{Binding TouchMouseStickVertScale}" 
															MinWidth="60"
															Minimum="0" Maximum="400" Increment="10" 
															VerticalAlignment="Center"/>
										<Label Content="%" Margin="4,0,0,0" VerticalAlignment="Center"/>
									</StackPanel>

									<!-- Trackball -->
									<StackPanel Orientation="Horizontal" Height="20" Margin="{StaticResource spaceMargin}">
										<CheckBox Content="{lex:Loc Trackball}" 
												  IsChecked="{Binding TouchMouseStickTrackball}" 
												  VerticalAlignment="Center" 
												  ToolTip="{lex:Loc TouchpadTrackballEnableTooltip}"/>
										<Label Content="{lex:Loc FrictionLabel}" Padding="0" 
											   Margin="20,0,5,0" VerticalAlignment="Center"/>
										<xctk:DoubleUpDown x:Name="touchStickFrictionUD" d:IsHidden="True" MinWidth="80" 
														   IsEnabled="{Binding TouchMouseStickTrackball}" 
														   Minimum="0.1" Maximum="20.0"
														   Value="{Binding TouchMouseStickTrackballFriction,FallbackValue='10'}"
														   ToolTip="{lex:Loc TouchpadTrackballFrictionTooltip}"
														   Margin="8,0,0,0" 
														   VerticalAlignment="Center"/>
									</StackPanel>

									<!-- MaxOutput -->
									<StackPanel Orientation="Horizontal" Margin="{StaticResource spaceMargin}">
										<CheckBox Content="{lex:Loc MaxOutput}" 
												  IsChecked="{Binding TouchMouseStickMaxOutputEnabled,FallbackValue=False}" 
												  HorizontalAlignment="Center" VerticalAlignment="Center"/>
										<xctk:DoubleUpDown d:IsHidden="True" Margin="8,0,0,0" 
														   Value="{Binding TouchMouseStickMaxOutput}" 
														   IsEnabled="{Binding TouchMouseStickMaxOutputEnabled,FallbackValue=False}"
														   FormatString="F0" MinWidth="60" 
														   Maximum="100.0" Minimum="0.0" Increment="10.0" 
														   VerticalAlignment="Center"/>
										<Label Content="%" Margin="4,0,0,0" VerticalAlignment="Center"/>
									</StackPanel>

									<!-- OutputCurve -->
