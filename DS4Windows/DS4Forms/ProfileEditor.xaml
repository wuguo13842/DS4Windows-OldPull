										<Button x:Name="gyroCalBtn3" Content="{lex:Loc GyroCalibration}" Width="100" 
												Click="GyroCalibration_Click" VerticalAlignment="Center" MinHeight="24"/>
									</StackPanel>
								</StackPanel>
							</TabItem>
