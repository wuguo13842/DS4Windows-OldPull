															VerticalAlignment="Center" MinHeight="24"/>
										<Label Content="{lex:Loc DegreesPerSecond}" VerticalAlignment="Center" Margin="2,0,0,0"/>
									</StackPanel>

									<StackPanel Orientation="Horizontal" Margin="0,0,0,8">
										<Label Content="{lex:Loc DelayTime}" ContentStringFormat="{}{0}:" VerticalAlignment="Center"/>
