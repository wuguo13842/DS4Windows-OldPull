										<CheckBox x:Name="dualSForceGenRumbleRescale" IsChecked="{Binding EnableGenericRumbleStrRescaleForDualSenseDevices}" 
												  Content="{lex:Loc DualSRumbleForceGenericRescale}" ToolTip="{lex:Loc DualSRumbleForceGenericRescale_Tip}" 
												  Margin="3,8,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
									</StackPanel>
								</GroupBox>
							</StackPanel>
						</GroupBox>

