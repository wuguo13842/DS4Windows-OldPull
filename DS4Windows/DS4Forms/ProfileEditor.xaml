												<ComboBoxItem Content="100%" VerticalContentAlignment="Center"/>
												<ComboBoxItem Content="87%" VerticalContentAlignment="Center"/>
												<ComboBoxItem Content="75%" VerticalContentAlignment="Center"/>
												<ComboBoxItem Content="62%" VerticalContentAlignment="Center"/>
												<ComboBoxItem Content="50%" VerticalContentAlignment="Center"/>
												<ComboBoxItem Content="37%" VerticalContentAlignment="Center"/>
												<ComboBoxItem Content="25%" VerticalContentAlignment="Center"/>
												<ComboBoxItem Content="12%" VerticalContentAlignment="Center"/>
