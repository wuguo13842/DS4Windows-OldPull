												MinWidth="160" Click="GyroSwipeTrigBtn_Click" Margin="8,0,0,0"
												VerticalAlignment="Center" MinHeight="24">
											<Button.ContextMenu>
												<ContextMenu />
											</Button.ContextMenu>
										</Button>
									</StackPanel>

									<CheckBox Content="{lex:Loc TurnBehaviorTurnsGyro}" Margin="0,8,0,0"
